# Copiez ce fichier en .env.local pour le développement local,
# et renseignez les mêmes variables dans Vercel (Project → Settings → Environment Variables).

# Clé API Anthropic (génération des débriefs).
ANTHROPIC_API_KEY=sk-ant-...

# Mot de passe maître du coach : accès complet + génération des codes d'accès.
ACCESS_PASSWORD=choisissez-un-mot-de-passe-fort

# Secret de signature des sessions et des codes (chaîne aléatoire, gardez-la secrète).
# Générez-en une avec :  openssl rand -hex 32
AUTH_SECRET=remplacez-par-une-chaine-aleatoire-de-64-caracteres
